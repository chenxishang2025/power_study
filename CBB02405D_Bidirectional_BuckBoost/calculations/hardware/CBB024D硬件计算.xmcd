															<ml:id xml:space="preserve" subscript="out_max">V</ml:id>
															<ml:id xml:space="preserve" subscript="out_nom">I</ml:id>
															<ml:id xml:space="preserve">t</ml:id>
														</ml:sequence>
													</ml:apply>
													<ml:real>2</ml:real>
												</ml:apply>
											</ml:lambda>
											<ml:bounds>
												<ml:real>0</ml:real>
												<ml:apply>
													<ml:div/>
													<ml:real>1</ml:real>
													<ml:id xml:space="preserve" subscript="switch">f</ml:id>
												</ml:apply>
											</ml:bounds>
										</ml:apply>
									</ml:apply>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>3.5790944881871862</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="ampere"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="67"/>
				</region>
				<region region-id="12894" left="168" top="5799.75" width="204.75" height="9.75" align-x="196.5" align-y="5808" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="10">12.计算充电MOS电流有效值</f>
						</p>
					</text>
				</region>
				<region region-id="12312" left="192" top="5824.5" width="446.25" height="62.25" align-x="272.25" align-y="5868" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="mos_down_rms">i1</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:sqrt/>
									<ml:apply>
										<ml:mult/>
										<ml:id xml:space="preserve" subscript="switch">f</ml:id>
										<ml:apply>
											<ml:integral auto-algorithm="true" algorithm="adaptive"/>
											<ml:lambda>
												<ml:boundVars>
													<ml:id xml:space="preserve">t</ml:id>
												</ml:boundVars>
												<ml:apply>
													<ml:pow/>
													<ml:apply>
														<ml:id xml:space="preserve" subscript="mos_down">i1</ml:id>
														<ml:sequence>
															<ml:id xml:space="preserve" subscript="in_nom">V</ml:id>
															<ml:id xml:space="preserve" subscript="out_max">V</ml:id>
															<ml:id xml:space="preserve" subscript="out_nom">I</ml:id>
															<ml:id xml:space="preserve">t</ml:id>
														</ml:sequence>
													</ml:apply>
													<ml:real>2</ml:real>
												</ml:apply>
											</ml:lambda>
											<ml:bounds>
												<ml:real>0</ml:real>
												<ml:apply>
													<ml:div/>
													<ml:real>1</ml:real>
													<ml:id xml:space="preserve" subscript="switch">f</ml:id>
												</ml:apply>
											</ml:bounds>
										</ml:apply>
									</ml:apply>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>3.5790944881871867</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="ampere"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="68"/>
				</region>
				<region region-id="12896" left="168" top="5913.75" width="204.75" height="9.75" align-x="196.5" align-y="5922" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="10">13.构建输出电容计算函数：</f>
						</p>
					</text>
				</region>
				<region region-id="12898" left="204" top="5954.25" width="216.75" height="17.25" align-x="305.25" align-y="5964" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="c">Δi1</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve" subscript="in">v</ml:id>
									<ml:id xml:space="preserve" subscript="out">v</ml:id>
									<ml:id xml:space="preserve" subscript="o">i</ml:id>
									<ml:id xml:space="preserve">t</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:apply>
								<ml:minus/>
								<ml:apply>
									<ml:id xml:space="preserve" subscript="L">i1</ml:id>
									<ml:sequence>
										<ml:id xml:space="preserve" subscript="in">v</ml:id>
										<ml:id xml:space="preserve" subscript="out">v</ml:id>
										<ml:id xml:space="preserve" subscript="o">i</ml:id>
										<ml:id xml:space="preserve">t</ml:id>
									</ml:sequence>
								</ml:apply>
								<ml:id xml:space="preserve" subscript="o">i</ml:id>
							</ml:apply>
						</ml:define>
					</math>
					<rendering item-idref="69"/>
				</region>
				<region region-id="12901" left="168" top="5991.75" width="204.75" height="9.75" align-x="196.5" align-y="6000" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="10">14.绘制输出电容电流波形：</f>
						</p>
					</text>
				</region>
				<region region-id="13032" left="186" top="6012" width="829.5" height="255" align-x="186" align-y="6012" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<plot disable-calc="false" item-idref="70"/>
					<rendering item-idref="71"/>
				</region>
			</area>
			<rendering item-idref="72"/>
		</region>
		<region region-id="15960" left="114" top="6354.75" width="243.75" height="13.5" align-x="142.5" align-y="6366" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<f size="14">六、MOS选型计算：</f>
				</p>
			</text>
		</region>
		<region region-id="13045" left="0" top="6387" width="6000" align-x="6000" align-y="6396" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="" height="404.25">
			<area is-collapsed="false" name="" show-name="false" show-border="true" show-icon="true" show-timestamp="true" allow-expand="false" is-locked="false" timestamp="" top-lock-id="13045" bottom-lock-id="16034" bottom-tag="">
				<region region-id="13052" left="138" top="6423.75" width="305.25" height="9.75" align-x="147.75" align-y="6432" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>1.按照上述计算，取MOS电流最大值：</b>
						</p>
					</text>
				</region>
				<region region-id="16017" left="162" top="6458.25" width="81" height="17.25" align-x="215.25" align-y="6468" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="mos_peak">i</ml:id>
							<ml:apply>
								<ml:mult style="auto-select"/>
								<ml:real>6.5</ml:real>
								<ml:id xml:space="preserve">A</ml:id>
							</ml:apply>
						</ml:define>
					</math>
					<rendering item-idref="73"/>
				</region>
				<region region-id="13058" left="138" top="6525.75" width="305.25" height="9.75" align-x="147.75" align-y="6534" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>2.计算输入mos电流的有效值：</b>
						</p>
					</text>
				</region>
				<region region-id="13061" left="162" top="6560.25" width="84" height="17.25" align-x="209.25" align-y="6570" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="mos_rms">i</ml:id>
							<ml:apply>
								<ml:mult style="auto-select"/>
								<ml:real>3.579</ml:real>
								<ml:id xml:space="preserve">A</ml:id>
							</ml:apply>
						</ml:define>
					</math>
					<rendering item-idref="74"/>
				</region>
				<region region-id="13062" left="156" top="6591.75" width="531.75" height="9.75" align-x="165.75" align-y="6600" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Mos选型的额定电流值需按流过MOS最大电流的2倍余量以上（防止短路或故障下电流过大冲击损坏）</b>
						</p>
					</text>
				</region>
				<region region-id="13064" left="162" top="6626.25" width="94.5" height="17.25" align-x="216.75" align-y="6636" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:apply>
								<ml:mult/>
								<ml:id xml:space="preserve" subscript="mos_rms">i</ml:id>
								<ml:real>2</ml:real>
							</ml:apply>
							<ml:unitOverride>
								<ml:id xml:space="preserve">A</ml:id>
							</ml:unitOverride>
							<result xmlns="http://schemas.mathsoft.com/math30">
								<unitedValue>
									<ml:real>7.158</ml:real>
									<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
										<unitReference unit="ampere"/>
									</unitMonomial>
								</unitedValue>
							</result>
						</ml:eval>
					</math>
					<rendering item-idref="75"/>
				</region>
				<region region-id="13066" left="132" top="6663.75" width="531.75" height="9.75" align-x="141.75" align-y="6672" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>3.Mos选型的额定耐压值需大于最大电压输入时的耐压值1.25倍余量（防止尖峰击穿）</b>
						</p>
					</text>
				</region>
				<region region-id="13068" left="162" top="6698.25" width="93" height="17.25" align-x="225.75" align-y="6708" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:apply>
								<ml:mult/>
								<ml:id xml:space="preserve" subscript="in_max">V</ml:id>
								<ml:real>1.25</ml:real>
							</ml:apply>
							<ml:unitOverride>
								<ml:id xml:space="preserve">V</ml:id>
							</ml:unitOverride>
							<result xmlns="http://schemas.mathsoft.com/math30">
								<unitedValue>
									<ml:real>60</ml:real>
									<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
										<unitReference unit="volt"/>
									</unitMonomial>
								</unitedValue>
							</result>
						</ml:eval>
					</math>
					<rendering item-idref="76"/>
				</region>
				<region region-id="13069" left="144" top="6735.75" width="531.75" height="9.75" align-x="153.75" align-y="6744" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>根据上述计算，可以选取额定电流大于10A，且耐压值100V的MOS,下管mos选型和上管一样</b>
						</p>
					</text>
				</region>
				<region region-id="16029" left="144" top="6759.75" width="531.75" height="9.75" align-x="153.75" align-y="6768" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>考虑到自然冷的情况，为尽量降低导通损耗和开关损耗，应用时选择导通内阻尽量小，且Coss较小的MOS</b>
						</p>
					</text>
				</region>
			</area>
			<rendering item-idref="77"/>
		</region>
	</regions>
