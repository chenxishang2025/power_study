															<ml:id xml:space="preserve" subscript="p2">ω</ml:id>
														</ml:apply>
													</ml:apply>
												</ml:parens>
											</ml:apply>
										</ml:apply>
									</ml:apply>
									<ml:unitOverride>
										<ml:apply>
											<ml:div/>
											<ml:apply>
												<ml:plus/>
												<ml:apply>
													<ml:plus/>
													<ml:id xml:space="preserve" subscript="sc">K</ml:id>
													<ml:apply>
														<ml:mult/>
														<ml:apply>
															<ml:mult/>
															<ml:id xml:space="preserve" subscript="sc">K</ml:id>
															<ml:parens>
																<ml:apply>
																	<ml:plus/>
																	<ml:apply>
																		<ml:div/>
																		<ml:real>1</ml:real>
																		<ml:id xml:space="preserve" subscript="z1">ω</ml:id>
																	</ml:apply>
																	<ml:apply>
																		<ml:div/>
																		<ml:real>1</ml:real>
																		<ml:id xml:space="preserve" subscript="z2">ω</ml:id>
																	</ml:apply>
																</ml:apply>
															</ml:parens>
														</ml:apply>
														<ml:id xml:space="preserve">s</ml:id>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:mult/>
													<ml:apply>
														<ml:mult/>
														<ml:apply>
															<ml:div/>
															<ml:id xml:space="preserve" subscript="sc">K</ml:id>
															<ml:id xml:space="preserve" subscript="z1">ω</ml:id>
														</ml:apply>
														<ml:apply>
															<ml:div/>
															<ml:real>1</ml:real>
															<ml:id xml:space="preserve" subscript="z2">ω</ml:id>
														</ml:apply>
													</ml:apply>
													<ml:apply>
														<ml:pow/>
														<ml:id xml:space="preserve">s</ml:id>
														<ml:real>2</ml:real>
													</ml:apply>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:plus/>
												<ml:apply>
													<ml:plus/>
													<ml:id xml:space="preserve">s</ml:id>
													<ml:apply>
														<ml:mult/>
														<ml:parens>
															<ml:apply>
																<ml:plus/>
																<ml:apply>
																	<ml:div/>
																	<ml:real>1</ml:real>
																	<ml:id xml:space="preserve" subscript="p1">ω</ml:id>
																</ml:apply>
																<ml:apply>
																	<ml:div/>
																	<ml:real>1</ml:real>
																	<ml:id xml:space="preserve" subscript="p2">ω</ml:id>
																</ml:apply>
															</ml:apply>
														</ml:parens>
														<ml:apply>
															<ml:pow/>
															<ml:id xml:space="preserve">s</ml:id>
															<ml:real>2</ml:real>
														</ml:apply>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:mult/>
													<ml:apply>
														<ml:mult/>
														<ml:apply>
															<ml:div/>
															<ml:real>1</ml:real>
															<ml:id xml:space="preserve" subscript="p1">ω</ml:id>
														</ml:apply>
														<ml:apply>
															<ml:div/>
															<ml:real>1</ml:real>
															<ml:id xml:space="preserve" subscript="p2">ω</ml:id>
														</ml:apply>
													</ml:apply>
													<ml:apply>
														<ml:pow/>
														<ml:id xml:space="preserve">s</ml:id>
