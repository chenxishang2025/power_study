				<region region-id="13889" left="78" top="4293.75" width="220.5" height="87.75" align-x="78" align-y="4302" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="false">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Gc =</p>
						<p style="普通" margin-left="0" margin-right="0" text-indent="inherit" text-align="left" list-style-type="inherit" tabs="inherit">
							<sp count="4"/>2.974e14 s^2 + 1.869e18 s + 2.936e21</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp count="2"/>----------------------------------------</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp count="2"/>9.872e06 s^3 + 6.204e12 s^2 + 9.746e17 s</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp/>
						</p>
						<p style="普通" margin-left="0" margin-right="0" text-indent="inherit" text-align="left" list-style-type="inherit" tabs="inherit">dsys =</p>
						<p style="普通" margin-left="0" margin-right="0" text-indent="inherit" text-align="left" list-style-type="inherit" tabs="inherit">
							<sp count="3"/>24 z^3 - 23.25 z^2 - 23.99 z + 23.26</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp count="2"/>------------------------------------</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp count="2"/>z^3 - 1.24 z^2 + 0.2547 z - 0.01443</p>
					</text>
				</region>
