				<region region-id="13884" left="60" top="3837.75" width="367.5" height="19.5" align-x="60" align-y="3846" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f size="10">利计算过程复杂，使用matlab工具可快速计算得到相关系数</f>
						</p>
						<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f size="10">编写matlab的M文件</f>
						</p>
					</text>
				</region>
				<region region-id="13886" left="78" top="3867" width="426.75" height="408" align-x="78" align-y="3876" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">L=15E-6;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">RL=2E-3;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">C=440E-6;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">RC=5E-3;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Vin=24;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">Vout=48;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Iout=5;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">R=Vout/Iout;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Db=Vin/Vout;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">w0=Db/(sqrt(L*C));</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">wa=Db^2*R/L;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">wzc=1/RC/C;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Q=1/w0/(L/Db^2/R+(RC+RL/Db^2)*C);</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Gdiv=3.3/68;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">Gsample=1/3.3;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">s=tf(</c>
							</f>
							<f family="Courier New" charset="0">
								<c val="#a020f0">'s'</c>
							</f>
							<c val="#000">
								<f family="Courier New" charset="0">);</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">Gvd=Gdiv*Gsample*Vin*(1-s/wa)*(1+s/wzc)/Db^2/(1+s/Q/w0+s^2/w0^2)</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">wz1=3.142E3;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">wz2=3.142E3;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">wp1=3.142E5;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">wp2=3.142E5;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">ks=3.013E3;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Gc=ks*(1+s/wz1)*(1+s/wz2)/s/(1+s/wp1)/(1+s/wp2)</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">sys=Gvd*Gc;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">w=logspace(1,7);</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">p=bodeoptions;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">p.PhaseVisible=</c>
							</f>
							<c val="#a020f0">
								<f family="Courier New" charset="0">'on'</f>
							</c>
							<f family="Courier New" charset="0">
								<c val="#000">;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">p.FreqUnits=</c>
							</f>
							<f family="Courier New" charset="0">
								<c val="#a020f0">'Hz'</c>
							</f>
							<f family="Courier New" charset="0">
								<c val="#000">;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">margin(sys);</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">grid </f>
							</c>
							<c val="#a020f0">
								<f family="Courier New" charset="0">on</f>
							</c>
							<f family="Courier New" charset="0">
								<c val="#000">;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">ts=5e-6;<sp count="21"/>
								</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">dsys=c2d(Gc,ts,</c>
							</f>
