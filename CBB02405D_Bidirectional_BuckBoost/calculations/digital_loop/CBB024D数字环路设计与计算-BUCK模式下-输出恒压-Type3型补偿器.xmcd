				<region region-id="13678" left="90" top="3334.5" width="414.75" height="55.5" align-x="150" align-y="3366" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="true">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve" subscript="TYPE3c">G</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">s</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="sc">K</ml:id>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:mult/>
											<ml:parens>
												<ml:apply>
													<ml:plus/>
													<ml:real>1</ml:real>
													<ml:apply>
														<ml:div/>
														<ml:id xml:space="preserve">s</ml:id>
														<ml:id xml:space="preserve" subscript="z1">ω</ml:id>
													</ml:apply>
												</ml:apply>
											</ml:parens>
											<ml:parens>
												<ml:apply>
													<ml:plus/>
													<ml:real>1</ml:real>
													<ml:apply>
														<ml:div/>
														<ml:id xml:space="preserve">s</ml:id>
														<ml:id xml:space="preserve" subscript="z2">ω</ml:id>
													</ml:apply>
												</ml:apply>
											</ml:parens>
										</ml:apply>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve">s</ml:id>
												<ml:parens>
													<ml:apply>
														<ml:plus/>
														<ml:real>1</ml:real>
														<ml:apply>
															<ml:div/>
															<ml:id xml:space="preserve">s</ml:id>
															<ml:id xml:space="preserve" subscript="p1">ω</ml:id>
														</ml:apply>
													</ml:apply>
												</ml:parens>
											</ml:apply>
											<ml:parens>
												<ml:apply>
													<ml:plus/>
													<ml:real>1</ml:real>
													<ml:apply>
														<ml:div/>
														<ml:id xml:space="preserve">s</ml:id>
														<ml:id xml:space="preserve" subscript="p2">ω</ml:id>
													</ml:apply>
												</ml:apply>
											</ml:parens>
										</ml:apply>
									</ml:apply>
								</ml:apply>
								<ml:unitOverride>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:plus/>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve" subscript="sc">K</ml:id>
												<ml:apply>
													<ml:mult/>
													<ml:apply>
														<ml:mult/>
														<ml:id xml:space="preserve" subscript="sc">K</ml:id>
														<ml:parens>
															<ml:apply>
																<ml:plus/>
																<ml:apply>
																	<ml:div/>
																	<ml:real>1</ml:real>
																	<ml:id xml:space="preserve" subscript="z1">ω</ml:id>
																</ml:apply>
																<ml:apply>
																	<ml:div/>
																	<ml:real>1</ml:real>
																	<ml:id xml:space="preserve" subscript="z2">ω</ml:id>
																</ml:apply>
															</ml:apply>
														</ml:parens>
													</ml:apply>
													<ml:id xml:space="preserve">s</ml:id>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:apply>
													<ml:mult/>
													<ml:apply>
														<ml:div/>
														<ml:id xml:space="preserve" subscript="sc">K</ml:id>
														<ml:id xml:space="preserve" subscript="z1">ω</ml:id>
													</ml:apply>
													<ml:apply>
														<ml:div/>
														<ml:real>1</ml:real>
														<ml:id xml:space="preserve" subscript="z2">ω</ml:id>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:pow/>
													<ml:id xml:space="preserve">s</ml:id>
													<ml:real>2</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:plus/>
											<ml:apply>
												<ml:plus/>
												<ml:id xml:space="preserve">s</ml:id>
												<ml:apply>
													<ml:mult/>
													<ml:parens>
														<ml:apply>
															<ml:plus/>
															<ml:apply>
																<ml:div/>
																<ml:real>1</ml:real>
																<ml:id xml:space="preserve" subscript="p1">ω</ml:id>
															</ml:apply>
															<ml:apply>
																<ml:div/>
																<ml:real>1</ml:real>
																<ml:id xml:space="preserve" subscript="p2">ω</ml:id>
															</ml:apply>
														</ml:apply>
													</ml:parens>
													<ml:apply>
														<ml:pow/>
														<ml:id xml:space="preserve">s</ml:id>
														<ml:real>2</ml:real>
													</ml:apply>
												</ml:apply>
											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:apply>
													<ml:mult/>
													<ml:apply>
														<ml:div/>
														<ml:real>1</ml:real>
														<ml:id xml:space="preserve" subscript="p1">ω</ml:id>
													</ml:apply>
													<ml:apply>
														<ml:div/>
														<ml:real>1</ml:real>
														<ml:id xml:space="preserve" subscript="p2">ω</ml:id>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:pow/>
													<ml:id xml:space="preserve">s</ml:id>
													<ml:real>3</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:unitOverride>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="72"/>
				</region>
				<region region-id="13806" left="66" top="3441.75" width="367.5" height="9.75" align-x="66" align-y="3450" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
