				<region region-id="13807" left="348" top="3436.5" width="72.75" height="25.5" align-x="360" align-y="3450" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="#ff0" tag="">
					<math optimize="false" disable-calc="true">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve">s</ml:id>
							<ml:apply>
								<ml:mult style="auto-select"/>
								<ml:apply>
									<ml:div/>
									<ml:real>2</ml:real>
									<ml:id xml:space="preserve" subscript="s">T</ml:id>
								</ml:apply>
								<ml:parens>
									<ml:apply>
										<ml:div/>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">z</ml:id>
											<ml:real>1</ml:real>
										</ml:apply>
										<ml:apply>
											<ml:plus/>
											<ml:id xml:space="preserve">z</ml:id>
