				</region>
				<region region-id="13825" left="60" top="3531.75" width="367.5" height="19.5" align-x="60" align-y="3540" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f size="10">利计算过程复杂，使用matlab工具可快速计算得到相关系数</f>
						</p>
						<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f size="10">编写matlab的M文件</f>
						</p>
					</text>
				</region>
				<region region-id="13966" left="114" top="3567" width="227.25" height="455.25" align-x="114" align-y="3576" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">L=15E-6;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">RL=2E-3;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">C=440E-6;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">RC=5E-3;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Vin=48;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">Vout=40;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">Iout= 5;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">R=Vout/Iout;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">w0=1/(sqrt(L*C));</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">wzc=1/RC/C;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Q=1/w0/(L/R+(RC+RL)*C);</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Gdiv=3.3/68;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Gsample=1/3.3;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">s=tf(</c>
							</f>
							<c val="#a020f0">
								<f family="Courier New" charset="0">'s'</f>
							</c>
							<f family="Courier New" charset="0">
								<c val="#000">);</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">Gvd=Gdiv*Gsample*Vin*(1+s/wzc)/(1+s/Q/w0+s^2/w0^2)</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">wz1=3.142E3;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">wz2=3.142E3;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">wp1=3.142E5</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">wp2=3.142E5</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">ks=2.449E3</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">Gc=ks*(1+s/wz1)*(1+s/wz2)/s/(1+s/wp1)/(1+s/wp2)</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">sys=Gvd*Gc;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">w=logspace(1,7);</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">p=bodeoptions;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Courier New" charset="0">
								<c val="#000">p.PhaseVisible=</c>
							</f>
							<c val="#a020f0">
								<f family="Courier New" charset="0">'on'</f>
							</c>
							<c val="#000">
								<f family="Courier New" charset="0">;</f>
							</c>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<c val="#000">
								<f family="Courier New" charset="0">p.FreqUnits=</f>
							</c>
							<f family="Courier New" charset="0">
								<c val="#a020f0">'Hz'</c>
							</f>
							<f family="Courier New" charset="0">
								<c val="#000">;</c>
							</f>
						</p>
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
