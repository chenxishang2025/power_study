											</ml:apply>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve" subscript="1">a</ml:id>
												<ml:apply>
													<ml:pow/>
													<ml:id xml:space="preserve">z</ml:id>
													<ml:real>2</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:mult/>
											<ml:id xml:space="preserve" subscript="2">a</ml:id>
