													<ml:pow/>
													<ml:id xml:space="preserve">z</ml:id>
													<ml:real>2</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:apply>
										<ml:apply>
											<ml:mult/>
											<ml:id xml:space="preserve" subscript="2">b</ml:id>
											<ml:id xml:space="preserve">z</ml:id>
										</ml:apply>
									</ml:apply>
									<ml:id xml:space="preserve" subscript="3">b</ml:id>
