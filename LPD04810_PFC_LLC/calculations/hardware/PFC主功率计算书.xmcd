						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="11">
								<inlineAttr font-weight="normal">计算输入X电容容量：</inlineAttr>
							</f>
						</p>
					</text>
				</region>
				<region region-id="10962" left="108" top="5250" width="207" height="42.75" align-x="130.5" align-y="5274" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="x">C</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:div/>
									<ml:id xml:space="preserve" subscript="Ripple">IL</ml:id>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:real>8</ml:real>
											<ml:id xml:space="preserve" subscript="s">f</ml:id>
										</ml:apply>
										<ml:id xml:space="preserve" subscript="Ripple">Vac</ml:id>
									</ml:apply>
								</ml:apply>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>7.15112924225582E-07</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="farad"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="66"/>
				</region>
				<region region-id="10980" left="54" top="5306.25" width="531.75" height="12" align-x="63.75" align-y="5316" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="11">设计留有一定的余量，同时满足输入电压的要求，选用两颗1</f>
							<f family="Times New Roman" charset="0" size="11">uF/275VAC</f>
							<f size="11">的</f>
							<f family="Times New Roman" charset="0" size="11">X2</f>
							<f size="11">电容作为输入滤波电容</f>
						</p>
					</text>
				</region>
				<region region-id="10982" left="54" top="5355" width="531.75" height="10.5" align-x="63.75" align-y="5364" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="宋体" charset="134" size="11">压敏电压值应大于实际电路的电压值，一般应使用下式进行选择</f>
						</p>
					</text>
				</region>
				<region region-id="10989" left="114" top="5380.5" width="68.25" height="33.75" align-x="147.75" align-y="5400" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="true">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve">VmA</ml:id>
							<ml:apply>
								<ml:div/>
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve">a</ml:id>
									<ml:id xml:space="preserve">v</ml:id>
								</ml:apply>
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve">b</ml:id>
									<ml:id xml:space="preserve">c</ml:id>
								</ml:apply>
							</ml:apply>
						</ml:define>
					</math>
					<rendering item-idref="67"/>
				</region>
				<region region-id="10990" left="60" top="5426.25" width="375" height="36" align-x="69.75" align-y="5436" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="Times New Roman" charset="0" size="11">a</f>
							<f family="宋体" charset="134" size="11">为电路电压波动系数，一般取值</f>
							<f family="Times New Roman" charset="0" size="11">1.2</f>
							<f family="宋体" charset="134" size="11">，</f>
							<f family="Times New Roman" charset="0" size="11">b</f>
							<f family="宋体" charset="134" size="11">为压敏电阻误差，一般取值</f>
							<f family="Times New Roman" charset="0" size="11">0.85</f>
							<f family="宋体" charset="134" size="11">，</f>
							<f family="Times New Roman" charset="0" size="11">c</f>
							<f family="宋体" charset="134" size="11">为元件的老化系数，一般取值</f>
							<f family="Times New Roman" charset="0" size="11">0.9</f>
							<f family="宋体" charset="134" size="11">，</f>
							<f family="Times New Roman" charset="0" size="11">v</f>
							<f family="宋体" charset="134" size="11">为交流输入正常最大电压有效值，在交流电应用场合为峰值电压，取</f>
							<f family="Times New Roman" charset="0" size="11">253V</f>
							<f family="宋体" charset="134" size="11">的</f>
							<f family="Times New Roman" charset="0" size="11">1.414</f>
							<f family="宋体" charset="134" size="11">倍</f>
						</p>
					</text>
				</region>
				<region region-id="10991" left="120" top="5478.75" width="41.25" height="15.75" align-x="135" align-y="5490" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve">a</ml:id>
							<ml:real>1.2</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="68"/>
				</region>
				<region region-id="10992" left="120" top="5502.75" width="48.75" height="15.75" align-x="135.75" align-y="5514" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve">b</ml:id>
							<ml:real>0.85</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="69"/>
				</region>
				<region region-id="10993" left="120" top="5526.75" width="40.5" height="15.75" align-x="134.25" align-y="5538" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define warning="WarnRedefinedBIUnit" xmlns:ml="http://schemas.mathsoft.com/math30">
