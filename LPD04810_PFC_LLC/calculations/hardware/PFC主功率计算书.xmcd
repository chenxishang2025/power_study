					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="宋体" charset="134" size="11">查询相关手册可以选用</f>
							<f family="Times New Roman" charset="0" size="11">10D561K</f>
							<f family="宋体" charset="134" size="11">型号压敏电阻，其压敏电压范围为</f>
							<f family="Times New Roman" charset="0" size="11">504V~616V</f>
						</p>
					</text>
				</region>
			</area>
