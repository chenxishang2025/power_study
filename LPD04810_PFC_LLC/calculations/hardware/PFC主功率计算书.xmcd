				</region>
				<region region-id="10995" left="120" top="5550.75" width="79.5" height="15.75" align-x="135.75" align-y="5562" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
