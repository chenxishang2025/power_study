		<region region-id="9522" left="0" top="1269" width="6000" align-x="6000" align-y="1278" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="" height="410.25">
			<area is-collapsed="false" name="" show-name="false" show-border="true" show-icon="true" show-timestamp="true" allow-expand="false" is-locked="false" timestamp="" top-lock-id="9522" bottom-lock-id="9520" bottom-tag="">
				<region region-id="10483" left="54" top="1293" width="503.25" height="21" align-x="63.75" align-y="1302" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="11">
								<inlineAttr font-weight="normal">输入电流交流电经流经整流桥整流，即流过整流桥最大的电流为输入AC的最大电流，取1.5倍余量，计算选型整流桥的额定电流值：</inlineAttr>
							</f>
						</p>
					</text>
				</region>
				<region region-id="10493" left="78" top="1332.75" width="55.5" height="20.25" align-x="107.25" align-y="1344" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="B">IK</ml:id>
							<ml:real>1.5</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="18"/>
				</region>
				<region region-id="10494" left="78" top="1362.75" width="173.25" height="20.25" align-x="125.25" align-y="1374" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="BriRate">I</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="B">IK</ml:id>
									<ml:id xml:space="preserve" subscript="acAvg">I</ml:id>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>4.0792931535319088</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="ampere"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="19"/>
				</region>
				<region region-id="10492" left="54" top="1400.25" width="531.75" height="24" align-x="63.75" align-y="1410" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="11">整流桥某个二极管承受负向电压截止时，该二极管上承受的电压为</f>
							<f family="Times New Roman" charset="0" size="11">PFC</f>
							<f size="11">直流母线电压，选取整流桥电压应力余量参数为</f>
							<f family="Times New Roman" charset="0" size="11">1.3</f>
							<f size="11">，则计算得到需要选取整流桥器件的电压应力</f>
						</p>
					</text>
				</region>
				<region region-id="10521" left="78" top="1440.75" width="60" height="20.25" align-x="111.75" align-y="1452" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="B">VK</ml:id>
							<ml:real>1.3</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="20"/>
				</region>
				<region region-id="10522" left="78" top="1470.75" width="163.5" height="20.25" align-x="129.75" align-y="1482" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="BriRate">V</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="B">VK</ml:id>
									<ml:id xml:space="preserve" subscript="bus">V</ml:id>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">V</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>494</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="volt"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="21"/>
				</region>
				<region region-id="10525" left="54" top="1509" width="531.75" height="10.5" align-x="63.75" align-y="1518" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="11">
								<inlineAttr font-weight="normal">计算整流桥最大损耗值：</inlineAttr>
							</f>
						</p>
					</text>
				</region>
				<region region-id="10526" left="54" top="1533" width="531.75" height="10.5" align-x="63.75" align-y="1542" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="11">
								<inlineAttr font-weight="normal">计算整流桥导通时的管压降V_F为0.9V</inlineAttr>
							</f>
						</p>
					</text>
				</region>
				<region region-id="10565" left="78" top="1560.75" width="72" height="20.25" align-x="115.5" align-y="1572" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="BriF">V</ml:id>
							<ml:apply>
								<ml:mult style="auto-select"/>
								<ml:real>0.9</ml:real>
								<ml:id xml:space="preserve">V</ml:id>
							</ml:apply>
						</ml:define>
					</math>
					<rendering item-idref="22"/>
				</region>
				<region region-id="10566" left="78" top="1578" width="180" height="38.25" align-x="108" align-y="1602" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="Bri">P</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:mult/>
										<ml:real>2</ml:real>
										<ml:id xml:space="preserve" subscript="BriF">V</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:div/>
										<ml:id xml:space="preserve" subscript="acAvg">I</ml:id>
										<ml:real>2</ml:real>
									</ml:apply>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">W</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>2.4475758921191453</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="watt"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="23"/>
				</region>
				<region region-id="10585" left="54" top="1628.25" width="531.75" height="24" align-x="63.75" align-y="1638" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="11">综合上述，整流桥选型的平均电流应力需大于</f>
							<f family="Times New Roman" charset="0" size="11">4.079A</f>
							<f size="11">，电压应力需大于</f>
							<f family="Times New Roman" charset="0" size="11">494V</f>
							<f size="11">。设计中选用的整流桥型号为</f>
							<f family="Times New Roman" charset="0" size="11">GBJ2506</f>
							<f size="11">，该整流桥耐压能力</f>
							<f family="Times New Roman" charset="0" size="11">600V</f>
							<f size="11">，平均电流能力</f>
							<f family="Times New Roman" charset="0" size="11">29A</f>
							<f size="12">。</f>
						</p>
					</text>
				</region>
			</area>
