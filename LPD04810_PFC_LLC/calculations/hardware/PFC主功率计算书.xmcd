				<region region-id="10932" left="60" top="4730.25" width="531.75" height="12" align-x="69.75" align-y="4740" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="11">本设计使用两颗</f>
							<f family="Times New Roman" charset="0" size="11">120uF</f>
							<f size="11">的母线电容</f>
						</p>
					</text>
				</region>
				<region region-id="10935" left="60" top="4754.25" width="370.5" height="70.5" align-x="69.75" align-y="4764" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="宋体" charset="134" size="11">事实上，</f>
							<f family="Times New Roman" charset="0" size="11">PFC</f>
							<f family="宋体" charset="134" size="11">母线电容容量大小的应用没统一计算公式，根据实际应用场合选择合适的电容大小，当电容容量较小，母线纹波越大，为了保证后级</f>
							<f family="Times New Roman" charset="0" size="11">DC-DC</f>
							<f family="宋体" charset="134" size="11">输出较稳定的电压，</f>
							<f family="Times New Roman" charset="0" size="11">DC-DC</f>
							<f family="宋体" charset="134" size="11">侧的控制带宽和相应就要求越快，同时输入掉电后输出掉电的时间间隔就越短；反之，母线电容越大，母线电压越平滑，后级</f>
							<f family="Times New Roman" charset="0" size="11">DC-DC</f>
							<f family="宋体" charset="134" size="11">控制压力较小，输入调电后输出保持时间较长。常规应用场合情况下对于普通应用场合，通常按照</f>
							<f family="Times New Roman" charset="0" size="11">1kW</f>
							<f family="宋体" charset="134" size="11">配置</f>
							<f family="Times New Roman" charset="0" size="11">200uF</f>
							<f family="宋体" charset="134" size="11">的母线电容经验设计。</f>
						</p>
					</text>
				</region>
			</area>
			<rendering item-idref="61"/>
		</region>
		<region region-id="10943" left="30" top="4891.5" width="174.75" height="12" align-x="55.5" align-y="4902" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#ffff80" tag="">
