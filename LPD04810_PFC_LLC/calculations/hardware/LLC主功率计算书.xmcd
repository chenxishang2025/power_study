						</p>
					</text>
				</region>
				<region region-id="14118" left="90" top="6622.5" width="213.75" height="41.25" align-x="123.75" align-y="6645" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="out">C</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:div/>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult style="auto-select"/>
											<ml:apply>
												<ml:mult style="auto-select"/>
												<ml:real>60</ml:real>
												<ml:apply>
													<ml:pow/>
													<ml:real>10</ml:real>
													<ml:real>-6</ml:real>
												</ml:apply>
											</ml:apply>
											<ml:id xml:space="preserve">F</ml:id>
										</ml:apply>
										<ml:id xml:space="preserve">Ω</ml:id>
									</ml:apply>
									<ml:id xml:space="preserve" subscript="ESR">R</ml:id>
								</ml:apply>
