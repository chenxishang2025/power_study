				<region region-id="14028" left="54" top="6672" width="224.25" height="10.5" align-x="82.5" align-y="6681" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<f size="11">
								<inlineAttr font-weight="normal">输出采用470uF的电容，计算总电容颗数：</inlineAttr>
							</f>
						</p>
					</text>
				</region>
				<region region-id="14139" left="90" top="6699" width="199.5" height="41.25" align-x="130.5" align-y="6723" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="cout">N</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:id xml:space="preserve">round</ml:id>
									<ml:apply>
										<ml:div/>
										<ml:id xml:space="preserve" subscript="out">C</ml:id>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:mult/>
												<ml:real>470</ml:real>
												<ml:apply>
													<ml:pow/>
													<ml:real>10</ml:real>
													<ml:real>-6</ml:real>
												</ml:apply>
											</ml:apply>
											<ml:id xml:space="preserve">F</ml:id>
										</ml:apply>
									</ml:apply>
								</ml:apply>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<ml:real>3</ml:real>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="84"/>
				</region>
				<region region-id="14140" left="54" top="6756" width="224.25" height="10.5" align-x="82.5" align-y="6765" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
