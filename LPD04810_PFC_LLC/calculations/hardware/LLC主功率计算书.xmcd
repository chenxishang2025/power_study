									<unitedValue>
										<ml:real>0.0014502775428260357</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="farad"/>
										</unitMonomial>
									</unitedValue>
								</result>
