				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
					<f family="宋体" charset="134" size="11">以工频</f>
					<f family="Times New Roman" charset="0" size="11">50Hz</f>
					<f family="宋体" charset="134" size="11">为例说明，若锁相环计算频率为</f>
					<f family="Times New Roman" charset="0" size="11">45kHz</f>
					<f family="宋体" charset="134" size="11">（开关周期，单周期计算），即在半个工频周期</f>
					<f family="宋体" charset="134" size="11">内总共可以计算</f>
					<f family="Times New Roman" charset="0" size="11">450</f>
					<f family="宋体" charset="134" size="11">次：</f>
				</p>
			</text>
		</region>
