		<region region-id="1979" left="54" top="8883" width="466.5" height="10.5" align-x="63.75" align-y="8892" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="0" margin-right="0" text-indent="inherit" text-align="left" list-style-type="inherit" tabs="inherit">
					<f family="宋体" charset="134" size="11">小功率时屏蔽前馈功能，当功率到一定程度时加入：</f>
				</p>
			</text>
		</region>
		<region region-id="1981" left="54" top="8913" width="466.5" height="10.5" align-x="63.75" align-y="8922" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="0" margin-right="0" text-indent="inherit" text-align="left" list-style-type="inherit" tabs="inherit">
					<f family="宋体" charset="134" size="11">定义50W加入前馈，25W退出前馈（滞环效果）：</f>
				</p>
			</text>
		</region>
		<region region-id="1984" left="96" top="8938.5" width="351.75" height="38.25" align-x="195.75" align-y="8958" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#0ff" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:id xml:space="preserve">MIN_POWER_RE</ml:id>
					<ml:eval placeholderMultiplicationStyle="default">
						<ml:apply>
							<ml:mult/>
							<ml:apply>
								<ml:mult/>
								<ml:apply>
									<ml:div/>
									<ml:apply>
										<ml:mult style="auto-select"/>
										<ml:real>50</ml:real>
										<ml:id xml:space="preserve">W</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:id xml:space="preserve" subscript="Lmax">I</ml:id>
										<ml:id xml:space="preserve" subscript="ACN_max">V</ml:id>
									</ml:apply>
								</ml:apply>
								<ml:id xml:space="preserve">Q15</ml:id>
							</ml:apply>
							<ml:id xml:space="preserve">Q15</ml:id>
						</ml:apply>
						<result xmlns="http://schemas.mathsoft.com/math30">
							<ml:real>7314815.88664078</ml:real>
						</result>
					</ml:eval>
				</ml:define>
				<resultFormat numeric-only="true">
					<general precision="6" show-trailing-zeros="false" radix="dec" complex-threshold="10" zero-threshold="15" imaginary-value="i" exponential-threshold="3"/>
					<matrix display-style="auto" expand-nested-arrays="false"/>
					<unit format-units="true" simplify-units="true" fractional-unit-exponent="false"/>
				</resultFormat>
			</math>
			<rendering item-idref="132"/>
		</region>
		<region region-id="1986" left="96" top="8992.5" width="332.25" height="38.25" align-x="176.25" align-y="9012" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#0ff" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
