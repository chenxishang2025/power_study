		<region region-id="11656" left="72" top="527.25" width="250.5" height="13.5" align-x="100.5" align-y="538.5" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<f size="14">二、单相桥式整流滤波电路计算：</f>
				</p>
			</text>
		</region>
		<region region-id="12235" left="0" top="561" width="6008.25" align-x="0" align-y="561" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="" height="758.25">
			<area is-collapsed="true" name="" show-name="false" show-border="true" show-icon="true" show-timestamp="true" allow-expand="false" is-locked="false" timestamp="" top-lock-id="11650" bottom-lock-id="11653">
				<region region-id="2083" left="90" top="18" width="231" height="9.75" align-x="90" align-y="26.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"> 留有一定余量，取输入最低电压为110V设计反激</p>
					</text>
				</region>
				<region region-id="2084" left="114" top="45" width="74.25" height="20.25" align-x="162" align-y="56.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="busms">V</ml:id>
							<ml:real>110</ml:real>
						</ml:define>
					</math>
				</region>
				<region region-id="11588" left="96" top="77.25" width="375.75" height="22.5" align-x="96" align-y="86.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<f family="???" charset="1" size="9">
								<c val="#000">整流桥体内二极管交替工作，即当一对工作时，另一对截止，截止时两端电压为输入电压，当输入电网电压最高时，整流桥承受最大的耐压，取1.5倍余量，则选用的整流桥耐压需满足：</c>
							</f>
						</p>
					</text>
				</region>
				<region region-id="11622" left="114" top="111" width="56.25" height="20.25" align-x="146.25" align-y="122.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="bri">K</ml:id>
							<ml:real>1.5</ml:real>
						</ml:define>
					</math>
				</region>
				<region region-id="11623" left="114" top="141" width="135.75" height="20.25" align-x="196.5" align-y="152.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:apply>
								<ml:mult/>
								<ml:id xml:space="preserve" subscript="busmax">V</ml:id>
								<ml:id xml:space="preserve" subscript="bri">K</ml:id>
							</ml:apply>
							<ml:unitOverride>
								<ml:id xml:space="preserve">V</ml:id>
							</ml:unitOverride>
							<result xmlns="http://schemas.mathsoft.com/math30">
								<unitedValue>
									<ml:real>562.14989104330527</ml:real>
									<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
										<unitReference unit="volt"/>
									</unitMonomial>
								</unitedValue>
							</result>
						</ml:eval>
					</math>
				</region>
				<region region-id="11662" left="102" top="174" width="361.5" height="9.75" align-x="105" align-y="182.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">计算输出功率（忽略辅助绕组） </p>
					</text>
				</region>
				<region region-id="11670" left="114" top="195" width="132" height="20.25" align-x="148.5" align-y="206.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="out">P</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="out">V</ml:id>
									<ml:id xml:space="preserve" subscript="out">I</ml:id>
								</ml:apply>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<ml:real>60</ml:real>
								</result>
							</ml:eval>
						</ml:define>
					</math>
				</region>
				<region region-id="11664" left="96" top="228" width="231" height="9.75" align-x="96" align-y="236.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"> 假设反激电源工作效率为80%，计算原边输入功率</p>
					</text>
				</region>
				<region region-id="11671" left="114" top="249" width="47.25" height="15.75" align-x="130.5" align-y="260.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve">η</ml:id>
							<ml:apply>
								<ml:mult style="auto-select"/>
								<ml:real>80</ml:real>
								<ml:id xml:space="preserve">%</ml:id>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="11672" left="114" top="272.25" width="101.25" height="38.25" align-x="141.75" align-y="296.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="in">P</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:div/>
									<ml:id xml:space="preserve" subscript="out">P</ml:id>
									<ml:id xml:space="preserve">η</ml:id>
								</ml:apply>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<ml:real>75</ml:real>
								</result>
							</ml:eval>
						</ml:define>
					</math>
				</region>
				<region region-id="11591" left="96" top="324" width="375.75" height="19.5" align-x="96" align-y="332.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">当输入电压最低，且输出满功率时，此时流过整流桥的电流最大，此时流过整流桥每个二极管的电流平均值为：</p>
					</text>
				</region>
				<region region-id="11617" left="114" top="350.25" width="163.5" height="42.75" align-x="160.5" align-y="374.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="inmax">I</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:div/>
									<ml:id xml:space="preserve" subscript="in">P</ml:id>
									<ml:apply>
										<ml:mult/>
										<ml:id xml:space="preserve" subscript="acmin">V</ml:id>
										<ml:real>2</ml:real>
									</ml:apply>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>0.44117647058823528</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="ampere"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
				</region>
				<region region-id="11593" left="96" top="401.25" width="375.75" height="11.25" align-x="96" align-y="410.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">其中，<f family="Times New Roman" charset="0">2</f>表示整流桥是交替工作的，留<f family="Times New Roman" charset="0">1.5</f>倍余量计算选取整流桥电流</p>
					</text>
				</region>
				<region region-id="11613" left="114" top="423" width="60.75" height="20.25" align-x="150.75" align-y="434.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="bri">IK</ml:id>
							<ml:real>1.5</ml:real>
						</ml:define>
					</math>
				</region>
				<region region-id="11614" left="114" top="459" width="125.25" height="20.25" align-x="191.25" align-y="470.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:apply>
								<ml:mult/>
								<ml:id xml:space="preserve" subscript="inmax">I</ml:id>
								<ml:id xml:space="preserve" subscript="bri">IK</ml:id>
							</ml:apply>
							<ml:unitOverride>
								<ml:id xml:space="preserve">A</ml:id>
							</ml:unitOverride>
							<result xmlns="http://schemas.mathsoft.com/math30">
								<unitedValue>
									<ml:real>0.66176470588235292</ml:real>
									<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
										<unitReference unit="ampere"/>
									</unitMonomial>
								</unitedValue>
							</result>
						</ml:eval>
					</math>
				</region>
				<region region-id="11596" left="96" top="492" width="375.75" height="9.75" align-x="96" align-y="500.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">假设整流桥的二极管的道荣压降为1V，则整流桥的损耗计算为：</p>
					</text>
				</region>
				<region region-id="11607" left="114" top="519" width="57" height="20.25" align-x="145.5" align-y="530.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="bri">V</ml:id>
							<ml:apply>
								<ml:mult style="auto-select"/>
								<ml:real>1</ml:real>
								<ml:id xml:space="preserve">V</ml:id>
							</ml:apply>
						</ml:define>
					</math>
				</region>
				<region region-id="11608" left="114" top="555" width="164.25" height="20.25" align-x="145.5" align-y="566.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="bri">P</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:mult/>
										<ml:real>2</ml:real>
										<ml:id xml:space="preserve" subscript="bri">V</ml:id>
									</ml:apply>
									<ml:id xml:space="preserve" subscript="inmax">I</ml:id>
								</ml:apply>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<ml:real>0.88235294117647056</ml:real>
								</result>
							</ml:eval>
						</ml:define>
					</math>
				</region>
				<region region-id="11599" left="96" top="593.25" width="456" height="11.25" align-x="96" align-y="602.25" show-border="false" show-highlight="true" is-protected="true" z-order="0" background-color="#ff0" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">根据上述计算选用的整流桥型号为<f family="Times New Roman" charset="0">KBL606</f>，其额定工作电压为<f family="Times New Roman" charset="0">600V</f>，额定电流为<f family="Times New Roman" charset="0">6A</f>，完全满足设计要求</p>
					</text>
				</region>
				<region region-id="11600" left="90" top="624" width="231" height="9.75" align-x="90" align-y="632.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"> 留有一定余量，取输入最低电压为110V设计反激</p>
					</text>
				</region>
				<region region-id="11601" left="114" top="645" width="52.5" height="20.25" align-x="132" align-y="656.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="c">t</ml:id>
							<ml:real>0.008</ml:real>
						</ml:define>
					</math>
				</region>
				<region region-id="11602" left="114" top="663.75" width="241.5" height="63.75" align-x="141.75" align-y="704.25" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="in">C</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:div/>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:real>2</ml:real>
											<ml:id xml:space="preserve" subscript="out">P</ml:id>
										</ml:apply>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:div/>
													<ml:real>1</ml:real>
													<ml:apply>
														<ml:mult style="auto-select"/>
														<ml:real>2</ml:real>
														<ml:id xml:space="preserve" subscript="L">f</ml:id>
													</ml:apply>
												</ml:apply>
												<ml:id xml:space="preserve" subscript="c">t</ml:id>
											</ml:apply>
										</ml:parens>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:id xml:space="preserve">η</ml:id>
										<ml:parens>
											<ml:apply>
												<ml:minus/>
												<ml:apply>
													<ml:mult/>
													<ml:real>2</ml:real>
													<ml:apply>
														<ml:pow/>
														<ml:id xml:space="preserve" subscript="acmin">V</ml:id>
														<ml:real>2</ml:real>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:pow/>
													<ml:id xml:space="preserve" subscript="busms">V</ml:id>
													<ml:real>2</ml:real>
												</ml:apply>
											</ml:apply>
										</ml:parens>
									</ml:apply>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">uF</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<ml:real>127.65957446808511</ml:real>
								</result>
							</ml:eval>
						</ml:define>
					</math>
				</region>
			</area>
			<rendering item-idref="13"/>
		</region>
		<region region-id="11679" left="66" top="597.75" width="250.5" height="13.5" align-x="94.5" align-y="609" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="标题 1" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<f size="14">三、变压器计算：</f>
				</p>
			</text>
		</region>
		<region region-id="11673" left="0" top="639" width="6000" align-x="6000" align-y="648" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="" height="1922.25">
			<area is-collapsed="false" name="" show-name="false" show-border="true" show-icon="true" show-timestamp="true" allow-expand="false" is-locked="false" timestamp="" top-lock-id="11673" bottom-lock-id="11803" bottom-tag="">
				<region region-id="2119" left="90" top="651.75" width="341.25" height="9.75" align-x="90" align-y="660" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"> 定义反激变压器初级绕组的感应电压为100V</p>
					</text>
				</region>
				<region region-id="2156" left="114" top="672.75" width="60.75" height="20.25" align-x="148.5" align-y="684" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="OR">V</ml:id>
							<ml:real>100</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="14"/>
				</region>
				<region region-id="2126" left="90" top="705.75" width="341.25" height="9.75" align-x="90" align-y="714" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"> 定义原边MOS开通后源漏极压降为</p>
					</text>
				</region>
				<region region-id="2158" left="114" top="726.75" width="43.5" height="20.25" align-x="141.75" align-y="738" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="ds">V</ml:id>
							<ml:real>4</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="15"/>
				</region>
